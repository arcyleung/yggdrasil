# Yggdrasil PoC — copy to .env and fill in.
# Spec: docs/superpowers/specs/2026-06-24-yggdrasil-mcp-trajectory-memory-design.md

YGG_SQLITE_PATH=./data/yggdrasil.db
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=yggdrasil_trajectories
# QDRANT_API_KEY=

# Embedder: OpenAI-compatible /v1/embeddings (vLLM, OpenAI, etc.)
# Example — local vLLM (server: --host 0.0.0.0 --port 8000, model Qwen/Qwen3-Embedding-0.6B):
EMBED_BASE_URL=http://127.0.0.1:8000/v1
EMBED_API_KEY=
EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBED_DIM=1024
# OpenAI cloud alternative:
# EMBED_BASE_URL=https://api.openai.com/v1
# EMBED_API_KEY=sk-...
# EMBED_MODEL=text-embedding-3-small
# EMBED_DIM=1536

YGG_DEFAULT_DOMAIN=coding
YGG_SEARCH_INCLUDE_OPEN=true
YGG_FUSION=rrf
YGG_W_TASK=1.0
YGG_W_SCAFFOLD=1.0
YGG_EFFORT_FILTER_MODE=inclusive_null
YGG_EMBED_VIEW_VERSION=coding_v1

# MONGO_URI=
YGG_MONGO_CREDS_FILE=mongo_creds.txt

# KEY_NAME_MAP=
KEY_NAME_MAP=