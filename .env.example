# Yggdrasil PoC — copy to .env and fill in.
# Spec: docs/superpowers/specs/2026-06-24-yggdrasil-mcp-trajectory-memory-design.md

YGG_SQLITE_PATH=./data/yggdrasil.db
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=yggdrasil_trajectories
# QDRANT_API_KEY=

# Embedder: OpenAI-compatible /v1/embeddings (vLLM, OpenAI, etc.)
# Example — local vLLM (server: --host 0.0.0.0 --port 8000, model Qwen/Qwen3-Embedding-0.6B):
EMBED_BASE_URL=http://127.0.0.1:8000/v1
EMBED_API_KEY=
EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBED_DIM=1024
# OpenAI cloud alternative:
# EMBED_BASE_URL=https://api.openai.com/v1
# EMBED_API_KEY=sk-...
# EMBED_MODEL=text-embedding-3-small
# EMBED_DIM=1536

YGG_DEFAULT_DOMAIN=coding
YGG_SEARCH_INCLUDE_OPEN=true
YGG_FUSION=rrf
YGG_W_TASK=1.0
YGG_W_SCAFFOLD=1.0
YGG_EFFORT_FILTER_MODE=inclusive_null
YGG_EMBED_VIEW_VERSION=coding_v1

# MONGO_URI=
YGG_MONGO_CREDS_FILE=mongo_creds.txt

# KEY_NAME_MAP=
KEY_NAME_MAP=
# Optional regex content scrub on write (emails, sk-/Bearer keys; preserve owner names). Default off.
YGG_SCRUB_CONTENT=0

# --- Multi-tenant / control plane (feat/multi-tenant) ---
# off = legacy PoC (default; existing tests pass). enforced = require principal on MCP/API.
YGG_TENANCY_MODE=off
YGG_DEFAULT_TENANT=lab
# Path to user_mapping.yaml (api_key -> owner). Also supports KEY_NAME_MAP env.
YGG_USER_MAPPING_PATH=
# Public HTTPS base URL for skill/MCP templates (Funnel / DDNS)
YGG_PUBLIC_BASE_URL=
YGG_UI_BIND=127.0.0.1:8080
YGG_DEMO_ENABLED=1
YGG_DEMO_OWNER=demo
# Optional well-known demo bearer (seeded hashed into api_tokens on startup)
# YGG_DEMO_TOKEN=ygg_demo_shared_token_change_me
YGG_TOKEN_TTL_DAYS=90
# stdio MCP: opaque bearer from token exchange / demo; required when TENANCY_MODE=enforced
# YGG_MCP_TOKEN=
